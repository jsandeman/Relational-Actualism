+            "strict_commit_loss_rate": round(sum(1 for r in items if bool(r.get("lost_strict_commit"))) / n, 6),
+            "selected_commit_loss_rate": round(sum(1 for r in items if bool(r.get("lost_selected_commit"))) / n, 6),
