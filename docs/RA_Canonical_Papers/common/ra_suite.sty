  \def\theta{theta}%
  \def\kappa{kappa}%
  \def\lambda{lambda}%
  \def\nu{nu}%
  \def\pi{pi}%
  \def\phi{phi}%
  \def\psi{psi}%
  \def\chi{chi}%
  \def\xi{xi}%
  \def\eta{eta}%
  \def\zeta{zeta}%
