% ra_suite.sty -- shared TeX style layer for the Relational Actualism paper suite.
% This file is intentionally conservative. It mirrors the package/macro surface
% already used by the canonical April 2026 RA papers and adds optional RAKB ID
% display support.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ra_suite}[2026/04/28 Relational Actualism shared paper style]

% Options
\newif\ifRAKBShowIDs
\RAKBShowIDsfalse
\DeclareOption{showrakbids}{\RAKBShowIDstrue}
\ProcessOptions\relax

% Page/font/math basics
\RequirePackage[margin=1in]{geometry}
\RequirePackage{mathptmx}
\RequirePackage{courier}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{amsmath,amssymb,amsthm,mathtools}
\RequirePackage{enumitem}
\RequirePackage{xcolor}
\RequirePackage{setspace}
\RequirePackage{titlesec}
\RequirePackage{booktabs}
\RequirePackage{tcolorbox}
\RequirePackage{array}
\RequirePackage{longtable}
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,linkcolor=blue,citecolor=blue,urlcolor=blue}
\setstretch{1.08}
\titleformat{\section}{\large\bfseries}{\thesection.}{0.6em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection.}{0.5em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection.}{0.5em}{}

% Robust definitions for mathptmx/hyperref interactions.
\let\RAoldhbar\hbar
\DeclareRobustCommand{\hbar}{\ensuremath{\hslash}}
\providecommand{\SRa}{\ensuremath{S_{\mathrm{RA}}}}
\providecommand{\Pacc}{\ensuremath{P_{\mathrm{acc}}}}
\providecommand{\Dkl}{\ensuremath{D_{\mathrm{KL}}}}
\providecommand{\TV}{\ensuremath{\mathrm{TV}}}
\providecommand{\RA}{Relational Actualism}
\providecommand{\BDG}{Benincasa--Dowker--Glaser}
\providecommand{\LLC}{Local Ledger Condition}

% Optional visible RAKB marks. By default these are non-rendering.
% The generator primarily writes source comments: % RAKB: RA-...
\newcommand{\RAKBID}[1]{%
  \ifRAKBShowIDs
    \marginpar{\raggedright\scriptsize\ttfamily RAKB: #1}%
  \fi
}

% Shared theorem-like environments. \providecommand cannot guard \newtheorem,
% so use a small existence check for common names.
\@ifundefined{axiom}{\newtheorem{axiom}{Axiom}}{}
\@ifundefined{definition}{\newtheorem{definition}{Definition}}{}
\@ifundefined{theorem}{\newtheorem{theorem}{Theorem}}{}
\@ifundefined{lemma}{\newtheorem{lemma}{Lemma}}{}
\@ifundefined{proposition}{\newtheorem{proposition}{Proposition}}{}
\@ifundefined{conjecture}{\newtheorem{conjecture}{Conjecture}}{}
\@ifundefined{corollary}{\newtheorem{corollary}{Corollary}}{}

